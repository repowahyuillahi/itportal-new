APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=itportal
DB_USERNAME=root
DB_PASSWORD=

SESSION_NAME=itportal_session
SESSION_LIFETIME_MINUTES=480

STORAGE_PATH=storage
EXPORT_PATH=storage/exports
UPLOAD_PATH=storage/uploads
MAX_UPLOAD_MB=5

# Optional: used only by database/seeders/admin_user.php (php scripts/seed.php).
# Leave blank to skip. Use scripts/create_admin.php for interactive setup.
ADMIN_EMAIL=
ADMIN_NAME=Administrator
ADMIN_PASSWORD=
